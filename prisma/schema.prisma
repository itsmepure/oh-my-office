// Multi-Office AI Platform — Prisma Schema
// 11 models matching design spec Section 5.
// PostgreSQL via Docker in dev. Swap DATABASE_URL for production.

generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─── User & Auth ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  agents            Agent[]
  officeMemberships OfficeMembership[]
  ownedOffices      Office[]
  subscription      Subscription?
  creditBalance     CreditBalance?
  creditLedger      CreditLedger[]
  llmKeys           LlmKey[]
  cryptoPayments    CryptoPayment[]

  @@index([email])
}

// ─── Agent Catalog ──────────────────────────────────────────────────────────

model Agent {
  id           String   @id @default(uuid())
  ownerId      String? // null = platform agent
  name         String
  role         String // Planner, Coder, Reviewer, Researcher, etc.
  systemPrompt String
  tools        Json     @default("[]")
  modelConfig  Json     @default("{}")
  createdAt    DateTime @default(now())

  owner          User?           @relation(fields: [ownerId], references: [id])
  knowledgeDocs  KnowledgeDoc[]
  templateAgents TemplateAgent[]

  @@index([ownerId])
  @@index([role])
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  agentId   String
  title     String
  content   String? // inline markdown/text (MVP)
  fileRef   String? // path to knowledge file (future)
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── Templates (Recipes) ────────────────────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String // dev, research, content, etc.
  workflow    Json // orderedStep[] — [{ order, agentRole, label }]
  createdAt   DateTime @default(now())

  templateAgents TemplateAgent[]
  offices        Office[]

  @@index([category])
}

model TemplateAgent {
  id         String @id @default(uuid())
  templateId String
  agentId    String
  stepOrder  Int // position in workflow pipeline

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id])

  @@unique([templateId, stepOrder])
  @@index([templateId])
  @@index([agentId])
}

// ─── Office Instances ───────────────────────────────────────────────────────

model Office {
  id            String   @id @default(uuid())
  name          String
  templateId    String
  ownerId       String
  workspacePath String
  status        String   @default("idle") // idle, running, paused
  createdAt     DateTime @default(now())

  template     Template           @relation(fields: [templateId], references: [id])
  owner        User               @relation(fields: [ownerId], references: [id])
  memberships  OfficeMembership[]
  officeAgents OfficeAgent[]
  tasks        Task[]
  events       Event[]

  @@index([ownerId])
  @@index([templateId])
}

model OfficeMembership {
  id       String @id @default(uuid())
  officeId String
  userId   String
  role     String @default("member") // owner | member

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([officeId, userId])
  @@index([userId])
}

model OfficeAgent {
  id            String @id @default(uuid())
  officeId      String
  agentSnapshot Json // full copy of Agent config at creation time
  stepOrder     Int // position in workflow

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
}

// ─── Tasks & Execution ──────────────────────────────────────────────────────

model Task {
  id         String    @id @default(uuid())
  officeId   String
  prompt     String
  status     String    @default("queued") // queued | running | done | failed
  priority   Int       @default(0) // higher = dequeued first (Team tier)
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  office    Office     @relation(fields: [officeId], references: [id])
  events    Event[]
  artifacts Artifact[]

  @@index([officeId])
  @@index([status])
  @@index([status, priority])
}

// ─── Real-time Events ───────────────────────────────────────────────────────

model Event {
  id       String   @id @default(uuid())
  taskId   String
  officeId String
  agentRef String? // role name of the emitting agent
  type     String // step.start, step.done, agent.thinking, task.status, etc.
  payload  Json // event-specific data matching shared Zod schemas
  ts       DateTime @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  office Office @relation(fields: [officeId], references: [id])

  @@index([taskId])
  @@index([officeId, ts])
}

// ─── Artifacts ──────────────────────────────────────────────────────────────

model Artifact {
  id        String   @id @default(uuid())
  taskId    String
  type      String // file | text | code
  name      String
  content   String? // inline content for text/code artifacts
  fileRef   String? // path to workspace file for file artifacts
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─── Monetization (Phase M0) ────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  TEAM
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  plan                 Plan      @default(FREE)
  status               String    @default("active") // active | past_due | canceled
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditBalance {
  id           String   @id @default(uuid())
  userId       String   @unique
  granted      Int      @default(0) // monthly grant remaining
  purchased    Int      @default(0) // bought packs (consumed after grant)
  grantResetAt DateTime // when `granted` refills

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Append-only audit of every credit movement. CreditBalance is the source of
// truth for the current balance; this is the immutable history.
model CreditLedger {
  id           String   @id @default(uuid())
  userId       String
  delta        Int // negative = spend, positive = grant/purchase/refund
  reason       String // task_step | monthly_grant | purchase | refund
  taskId       String?
  agentRef     String?
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// BYOK: a user (or one of their offices) can attach their own LLM key.
// Stored encrypted at rest (AES-256-GCM). Never returned to the browser.
model LlmKey {
  id         String   @id @default(uuid())
  userId     String
  officeId   String? // null = account-default; set = office override
  provider   String   @default("deepseek")
  baseUrl    String?
  model      String?
  last4      String // last 4 chars of the raw key, for masked display
  ciphertext String
  iv         String
  authTag    String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, officeId])
  @@index([userId])
}

// Crypto billing: USDC-on-Solana credit-pack payments (see CRYPTO_BILLING.md).
// One row per payment attempt. `reference` is a fresh Solana pubkey attached to
// the on-chain transfer so we can find + verify it without trusting the client.
model CryptoPayment {
  id             String    @id @default(uuid())
  userId         String
  reference      String    @unique // base58 Solana pubkey used as on-chain reference
  credits        Int // credits granted on confirmation
  expectedAmount String // USDC amount as a decimal string
  status         String    @default("pending") // pending | confirmed | expired | failed
  txSignature    String?   @unique // set once verified on-chain
  network        String    @default("devnet")
  createdAt      DateTime  @default(now())
  confirmedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
