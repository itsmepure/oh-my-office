// Multi-Office AI Platform — Prisma Schema
// 11 models matching design spec Section 5.
// PostgreSQL via Docker in dev. Swap DATABASE_URL for production.

generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─── User & Auth ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  agents            Agent[]
  officeMemberships OfficeMembership[]
  ownedOffices      Office[]

  @@index([email])
}

// ─── Agent Catalog ──────────────────────────────────────────────────────────

model Agent {
  id           String   @id @default(uuid())
  ownerId      String? // null = platform agent
  name         String
  role         String // Planner, Coder, Reviewer, Researcher, etc.
  systemPrompt String
  tools        Json     @default("[]")
  modelConfig  Json     @default("{}")
  createdAt    DateTime @default(now())

  owner          User?           @relation(fields: [ownerId], references: [id])
  knowledgeDocs  KnowledgeDoc[]
  templateAgents TemplateAgent[]

  @@index([ownerId])
  @@index([role])
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  agentId   String
  title     String
  content   String? // inline markdown/text (MVP)
  fileRef   String? // path to knowledge file (future)
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ─── Templates (Recipes) ────────────────────────────────────────────────────

model Template {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String // dev, research, content, etc.
  workflow    Json // orderedStep[] — [{ order, agentRole, label }]
  createdAt   DateTime @default(now())

  templateAgents TemplateAgent[]
  offices        Office[]

  @@index([category])
}

model TemplateAgent {
  id         String @id @default(uuid())
  templateId String
  agentId    String
  stepOrder  Int // position in workflow pipeline

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id])

  @@unique([templateId, stepOrder])
  @@index([templateId])
  @@index([agentId])
}

// ─── Office Instances ───────────────────────────────────────────────────────

model Office {
  id            String   @id @default(uuid())
  name          String
  templateId    String
  ownerId       String
  workspacePath String
  status        String   @default("idle") // idle, running, paused
  createdAt     DateTime @default(now())

  template     Template           @relation(fields: [templateId], references: [id])
  owner        User               @relation(fields: [ownerId], references: [id])
  memberships  OfficeMembership[]
  officeAgents OfficeAgent[]
  tasks        Task[]
  events       Event[]

  @@index([ownerId])
  @@index([templateId])
}

model OfficeMembership {
  id       String @id @default(uuid())
  officeId String
  userId   String
  role     String @default("member") // owner | member

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([officeId, userId])
  @@index([userId])
}

model OfficeAgent {
  id            String @id @default(uuid())
  officeId      String
  agentSnapshot Json // full copy of Agent config at creation time
  stepOrder     Int // position in workflow

  office Office @relation(fields: [officeId], references: [id], onDelete: Cascade)

  @@index([officeId])
}

// ─── Tasks & Execution ──────────────────────────────────────────────────────

model Task {
  id         String    @id @default(uuid())
  officeId   String
  prompt     String
  status     String    @default("queued") // queued | running | done | failed
  createdAt  DateTime  @default(now())
  finishedAt DateTime?

  office    Office     @relation(fields: [officeId], references: [id])
  events    Event[]
  artifacts Artifact[]

  @@index([officeId])
  @@index([status])
}

// ─── Real-time Events ───────────────────────────────────────────────────────

model Event {
  id       String   @id @default(uuid())
  taskId   String
  officeId String
  agentRef String? // role name of the emitting agent
  type     String // step.start, step.done, agent.thinking, task.status, etc.
  payload  Json // event-specific data matching shared Zod schemas
  ts       DateTime @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  office Office @relation(fields: [officeId], references: [id])

  @@index([taskId])
  @@index([officeId, ts])
}

// ─── Artifacts ──────────────────────────────────────────────────────────────

model Artifact {
  id        String   @id @default(uuid())
  taskId    String
  type      String // file | text | code
  name      String
  content   String? // inline content for text/code artifacts
  fileRef   String? // path to workspace file for file artifacts
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}
