# OpenOffice — environment template. Copy to .env (root) and apps/web/.env.local
# and fill in. NEVER commit the filled files.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://openoffice:openoffice@localhost:5432/openoffice

# ── Auth (NextAuth v5) ──────────────────────────────────────────────────────
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── BYOK key encryption (AES-256-GCM) ───────────────────────────────────────
# 32 bytes as 64 hex chars: `openssl rand -hex 32`
# MUST be identical in web AND orchestrator (web encrypts, orchestrator decrypts).
KEY_ENCRYPTION_SECRET=

# ── Platform LLM (DeepSeek / OpenAI-compatible) ─────────────────────────────
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
# Alternative: ANTHROPIC_API_KEY= (used only if LLM_API_KEY is unset)

# ── Realtime (orchestrator WebSocket) ───────────────────────────────────────
# Client connects here for live task events. In production behind nginx use
# ws://<host>/ws (proxied to the orchestrator). Default for local dev:
ORCHESTRATOR_WS_URL=ws://localhost:3001
# ORCHESTRATOR_WS_PORT=3001

# ── Workspace storage root (absolute path) ──────────────────────────────────
# Where agent file output lives. Default is repo-relative ./workspaces.
WORKSPACES_ROOT=/opt/oh-my-office/workspaces

# ── Execution safety (Phase L4) — all optional, sane defaults ───────────────
# STEP_TIMEOUT_MS=180000              # per-agent-step wall-clock timeout
# WORKSPACE_MAX_FILE_BYTES=5242880    # 5 MB per file
# WORKSPACE_MAX_TOTAL_BYTES=52428800  # 50 MB per office workspace
# ORCHESTRATOR_MAX_CONCURRENT=3       # parallel tasks per worker
# TOKENS_PER_CREDIT=6000              # credit metering tuning

# ── Billing (Lemon Squeezy) — optional; billing dormant if unset ────────────
# LEMON_WEBHOOK_SECRET=
# LEMON_VARIANT_PRO=
# LEMON_VARIANT_TEAM=
# LEMON_VARIANT_PACK_SMALL=
# LEMON_VARIANT_PACK_MED=
# LEMON_VARIANT_PACK_LARGE=
# LEMON_CHECKOUT_PRO=
# LEMON_CHECKOUT_TEAM=
# LEMON_CHECKOUT_PACK_SMALL=
# LEMON_CHECKOUT_PACK_MED=
# LEMON_CHECKOUT_PACK_LARGE=
# LEMON_PORTAL_URL=
