{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./offices": {
      "types": "./dist/offices.d.ts",
      "import": "./dist/offices.js",
      "default": "./dist/offices.js"
    },
    "./agents": {
      "types": "./dist/agents.d.ts",
      "import": "./dist/agents.js",
      "default": "./dist/agents.js"
    },
    "./tasks": {
      "types": "./dist/tasks.d.ts",
      "import": "./dist/tasks.js",
      "default": "./dist/tasks.js"
    },
    "./credits": {
      "types": "./dist/credits.d.ts",
      "import": "./dist/credits.js",
      "default": "./dist/credits.js"
    },
    "./keys": {
      "types": "./dist/keys.d.ts",
      "import": "./dist/keys.js",
      "default": "./dist/keys.js"
    },
    "./entitlements": {
      "types": "./dist/entitlements.d.ts",
      "import": "./dist/entitlements.js",
      "default": "./dist/entitlements.js"
    },
    "./billing": {
      "types": "./dist/billing.d.ts",
      "import": "./dist/billing.js",
      "default": "./dist/billing.js"
    },
    "./members": {
      "types": "./dist/members.d.ts",
      "import": "./dist/members.js",
      "default": "./dist/members.js"
    },
    "./workspace": {
      "types": "./dist/workspace.d.ts",
      "import": "./dist/workspace.js",
      "default": "./dist/workspace.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "seed": "node --import tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/agents": "workspace:*",
    "@repo/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
